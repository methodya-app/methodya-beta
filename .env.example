# ============================================================
# Variables de entorno del BACKEND (configurar en Vercel:
# Project Settings > Environment Variables)
# ============================================================

# Supabase (Project Settings > API en el dashboard de Supabase)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # NUNCA exponer en el frontend
SUPABASE_ANON_KEY=eyJhbGciOi...           # usada solo por el backend para login

# MongoDB Atlas (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=methodya

# IA para generación de expresiones regulares (Google Gemini)
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash

# Corrector ortográfico (LanguageTool). Opcional: si no se configura (ni aquí
# ni en Parámetros del servidor de la app), el botón "Revisar ortografía"
# usa la API pública gratuita de LanguageTool en vez de una cuenta Premium.
LANGUAGETOOL_USERNAME=
LANGUAGETOOL_API_KEY=

# Vaciamiento real en Google Docs/Slides (OAuth2 con Drive API, Docs API y
# Slides API habilitadas). Opcional: si no se configura (ni aquí ni en
# Parámetros del servidor), "Vaciar" usa el modo simulado de texto.
# GOOGLE_OAUTH_CLIENT_ID/SECRET vienen del OAuth Client ("Aplicación web")
# creado en Google Cloud. GOOGLE_OAUTH_REFRESH_TOKEN normalmente se obtiene
# usando el botón "Conectar cuenta de Google" en Parámetros del servidor
# (que lo guarda en la base de datos); esta variable es solo un respaldo si
# prefieres inyectarlo por entorno en vez de la base de datos.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Origen permitido para CORS (URL de GitHub Pages del frontend)
ALLOWED_ORIGIN=https://tu-usuario.github.io
