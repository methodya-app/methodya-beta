# ============================================================
# Variables para CORRER TODO EN LOCAL (dev-server.js + docker-compose).
# Copia este archivo a ".env.local" y complétalo. No se sube a git.
# ============================================================

# --- Supabase LOCAL (Supabase CLI + Docker) -----------------------------
# 1) npx supabase init   (solo la primera vez)
# 2) npx supabase start
# El comando imprime "API URL", "anon key" y "service_role key": cópialos
# aquí tal cual (cambian de máquina a máquina la primera vez que se generan).
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=pega-aqui-la-anon-key-que-imprimio-supabase-start
SUPABASE_SERVICE_ROLE_KEY=pega-aqui-la-service-role-key-que-imprimio-supabase-start

# --- MongoDB LOCAL (docker-compose.yml de este repo) --------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=methodya

# --- IA para generación de regex (opcional en local) ---------------------
# Si la dejas vacía, el generador cae automáticamente en la heurística local
# (sin necesidad de internet ni de clave).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- CORS: URL del frontend local (Vite) ---------------------------------
ALLOWED_ORIGIN=http://localhost:5173

# --- Usuario admin de prueba creado por "npm run seed:local" (opcional) --
SEED_ADMIN_EMAIL=admin@methodya.local
SEED_ADMIN_PASSWORD=Methodya2026!
SEED_ADMIN_NOMBRE=Admin
SEED_ADMIN_APELLIDO=Methodya
